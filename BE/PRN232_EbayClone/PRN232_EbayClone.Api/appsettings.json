{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ebay_clone;Username=postgres;Password=YOUR_DB_PASSWORD;Include Error Detail=true",
    "Redis": "your_redis_ip:6399,password=your_redis_password"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "https://seqapi.mnhduc.site" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_minimum_32_characters_long_secret_key",
    "Issuer": "PRN232_EbayClone",
    "Audience": "PRN232_EbayClone_Client",
    "ExpiryMinutes": 10
  },
  "Email": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderName": "PRN232_EbayClone",
    "Username": "YOUR_EMAIL@gmail.com",
    "Password": "YOUR_APP_PASSWORD"
  },
  "EmailTemplate": {
    "TemplateFolder": "Mail/Templates"
  },
  "Cloudinary": {
    "CloudName": "YOUR_CLOUD_NAME",
    "ApiKey": "YOUR_API_KEY",
    "ApiSecret": "YOUR_API_SECRET"
  },
  "RedisRateLimits": [
    {
      "Path": "/api/RateLimited/limited",
      "Window": "30s",
      "MaxRequests": 5
    },
    {
      "PathRegex": "^/api/*",
      "Window": "1m",
      "MaxRequests": 60
    }
  ],
  "Twilio": {
    "Enabled": false,
    "AccountSid": "YOUR_TWILIO_ACCOUNT_SID",
    "AuthToken": "YOUR_TWILIO_AUTH_TOKEN",
    "FromNumber": "+1234567890"
  },
  "Google": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:5149",
      "https://localhost:7046",
      "http://localhost:7046",
      "https://prn232.mnhduc.site",
      "https://ebay.mnhduc.site"
    ]
  }
}
